// ICSE Project Tool — Prisma schema
// SQLite database storing: projects, agent runs, knowledge base, mocks, uploads

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============ Core entities ============

model Project {
  id          String      @id @default(cuid())
  title       String
  subject     String
  className   String      @map("class_name") // ICSE Class 9 or 10
  topic       String
  status      String      @default("pending") // pending | processing | completed | failed
  sourceText  String      @default("") @map("source_text")
  sourceName  String      @default("") @map("source_name") // original PDF filename
  outline     String      @default("") // JSON: agent outline
  finalOutput String      @default("") @map("final_output") // markdown final project
  images      String      @default("[]") // JSON array of image refs
  agentLogs   String      @default("[]") // JSON array of agent run logs
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  mocks       Mock[]
}

model Mock {
  id          String   @id @default(cuid())
  projectId   String?  @map("project_id")
  subject     String
  className   String   @map("class_name")
  topic       String
  difficulty  String   @default("medium") // easy | medium | hard
  questions   String   // JSON array of {q, options?, answer, marks, type}
  duration    Int      @default(120) // minutes
  createdAt   DateTime @default(now()) @map("created_at")

  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
}

// ============ Knowledge base (RAG source) ============

model KnowledgeChunk {
  id          String   @id @default(cuid())
  subject     String   // Physics | Chemistry | Biology | Math | History | Geography | Civics | English | Computer | Economics | General
  className   String   @default("10") @map("class_name")
  category    String   // syllabus | specimen_pattern | past_paper | textbook_summary | project_exemplar | glossary | rubric
  chapter     String   @default("")
  title       String
  content     String   // the actual text chunk
  tags        String   @default("") // comma-separated
  source      String   @default("manual") // manual | user_upload | web
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([subject, className, category])
  @@index([subject, chapter])
}

// ============ Cache (response + image dedupe) ============

model CacheEntry {
  id          String   @id @default(cuid())
  cacheKey    String   @unique @map("cache_key") // sha256 of inputs
  kind        String   // llm | image | mock
  value       String   // cached payload (text or image path)
  createdAt   DateTime @default(now()) @map("created_at")
  hits        Int      @default(0)
}

model Upload {
  id          String   @id @default(cuid())
  filename    String
  mimeType    String   @map("mime_type")
  size        Int
  extractedText String @default("") @map("extracted_text")
  createdAt   DateTime @default(now()) @map("created_at")
}
